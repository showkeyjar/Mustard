{
  "team_name": "mustard-claw",
  "heartbeat": {
    "daily_digest": true,
    "max_new_proposals_per_cycle": 1
  },
  "risk_policy": {
    "human_gate_required_change_types": [
      "runtime_control",
      "desktop_behavior",
      "training_data_policy",
      "default_model_or_tooling"
    ]
  },
  "decision_policy": {
    "owner": "arbiter",
    "escalate_on_uncertain_direction": true,
    "min_real_prompt_match_rate": 0.9,
    "min_pretrain_tool_match_rate": 0.95
  },
  "recursive_policy": {
    "enabled": true,
    "stagnation_rounds_to_pivot": 2,
    "force_max_landing_after_rounds": 3
  },
  "researcher_policy": {
    "min_frontier_observations": 3,
    "require_research_brief": true,
    "allow_external_search": true,
    "allow_external_fetch": true
  },
  "research_quality_policy": {
    "enabled": true,
    "max_rounds_without_new_failure_pattern": 2,
    "max_rounds_with_coverage_only_top_gap": 2,
    "require_nonempty_failure_patterns": true,
    "flag_zero_bridge_feedback_rounds": 3,
    "flag_zero_frontier_observation_rounds": 3
  },
  "role_evolution": {
    "enabled": true,
    "window_rounds": 5,
    "underperform_threshold": 0.45,
    "promote_threshold": 0.8,
    "max_underperform_rounds": 3
  },
  "eval_pipeline": {
    "auto_sync_real_prompt_eval": false,
    "min_new_candidates_to_merge": 4
  },
  "deep_cycle_policy": {
    "enabled": true,
    "require_positive_real_prompt_delta": true,
    "min_real_prompt_count": 20,
    "require_non_negative_control_success_delta": true,
    "require_at_least_one_proposal": true
  },
  "focus_areas": [
    "real_prompt_regression",
    "desktop_bridge_quality",
    "training_data_quality",
    "runtime_control_safety",
    "frontier_reasoning_model_tracking"
  ]
}
