{
  "team_name": "mustard-claw",
  "heartbeat": {
    "daily_digest": true,
    "max_new_proposals_per_cycle": 3
  },
  "risk_policy": {
    "human_gate_required_change_types": [
      "runtime_control",
      "desktop_behavior",
      "training_data_policy",
      "default_model_or_tooling"
    ]
  },
  "decision_policy": {
    "owner": "arbiter",
    "escalate_on_uncertain_direction": true,
    "min_real_prompt_match_rate": 0.9,
    "min_pretrain_tool_match_rate": 0.95
  },
  "recursive_policy": {
    "enabled": true,
    "stagnation_rounds_to_pivot": 2,
    "force_max_landing_after_rounds": 3
  },
  "researcher_policy": {
    "min_frontier_observations": 3,
    "require_research_brief": true,
    "allow_external_search": true,
    "allow_external_fetch": true
  },
  "role_evolution": {
    "enabled": true,
    "window_rounds": 5,
    "underperform_threshold": 0.45,
    "promote_threshold": 0.8,
    "max_underperform_rounds": 3
  },
  "focus_areas": [
    "real_prompt_regression",
    "desktop_bridge_quality",
    "training_data_quality",
    "runtime_control_safety",
    "frontier_reasoning_model_tracking"
  ]
}
